{
  "name": "ha-power-gauge",
  "version": "0.1.1",
  "description": "A glowing, animated power consumption gauge card for Home Assistant.",
  "main": "dist/ha-power-gauge.js",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c --watch",
    "dev": "concurrently -n build,serve -c blue,green \"rollup -c --watch\" \"serve -l 8000 .\"",
    "serve": "serve -l 8000 .",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "custom-card",
    "gauge",
    "power",
    "energy"
  ],
  "license": "MIT",
  "dependencies": {
    "custom-card-helpers": "^1.9.0",
    "lit": "^3.1.4"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "concurrently": "^8.2.2",
    "rollup": "^4.18.0",
    "serve": "^14.2.4",
    "tslib": "^2.6.3",
    "typescript": "^5.4.5"
  }
}
